@{
    ViewData["Title"] = "Upload Files";
}
@model PodcastsHosting.Models.AudioModelsViewModel

<h2 class="mb-3">Upload Files</h2>

<form asp-controller="Home" asp-action="Upload" method="post" enctype="multipart/form-data" class="mb-4">
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label asp-for="Upload.File" class="form-label">Audio file</label>
            <input asp-for="Upload.File" class="form-control" accept="@PodcastsHosting.Services.AudioFormats.FileInputAccept" required />
        </div>
        <div class="col-md-3">
            <label asp-for="Upload.BookName" class="form-label">Book Name</label>
            <input asp-for="Upload.BookName" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Upload.BookSeries" class="form-label">Series</label>
            <input asp-for="Upload.BookSeries" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Upload.ChapterTitle" class="form-label">Chapter Title</label>
            <input asp-for="Upload.ChapterTitle" class="form-control" />
        </div>
        <div class="col-md-1">
            <label asp-for="Upload.ChapterNumber" class="form-label">Chapter #</label>
            <input asp-for="Upload.ChapterNumber" class="form-control" />
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Upload</button>
        </div>
    </div>
</form>

@if (Model.AudioModels != null && Model.AudioModels.Any())
{
<div class="table-responsive">
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th class="text-nowrap">Size</th>
            <th>User</th>
            <th class="text-nowrap">Upload Time</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var audio in Model.AudioModels)
        {
            <tr>
                <td>
                    <div class="fw-semibold">@audio.FileName</div>
                    <div class="small text-muted text-break mt-1">@audio.FilePath</div>
                </td>
                <td class="text-nowrap">@FormatFileSize(audio.FileSize)</td>
                <td>@audio.UploadUser?.Email</td>
                <td class="text-nowrap">@audio.UploadTime.ToString("g")</td>
                <td>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Home" asp-action="Download" asp-route-id="@audio.Id" asp-route-download="true" class="btn btn-secondary btn-sm">Download</a>
                        <form asp-controller="Home" asp-action="Delete" asp-route-id="@audio.Id" method="post" class="m-0">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
}
else
{
<p class="text-muted">No audio files available.</p>
}

@functions {
    private static string FormatFileSize(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        var size = (double)bytes;
        var unitIndex = 0;

        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return unitIndex == 0
            ? $"{bytes} {units[unitIndex]}"
            : $"{size:0.#} {units[unitIndex]}";
    }
}